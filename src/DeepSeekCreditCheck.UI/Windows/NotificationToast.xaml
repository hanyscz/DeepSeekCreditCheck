<Window x:Class="DeepSeekCreditCheck.UI.Windows.NotificationToast"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeepSeek Credit Check"
        Width="380" Height="140"
        WindowStyle="None" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True"
        Background="#252525" Foreground="#E0E0E0"
        WindowStartupLocation="Manual"
        AllowsTransparency="True"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.3" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Border Background="#252525" CornerRadius="10" BorderBrush="#4CAF50" BorderThickness="2">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" FontSize="14"
                       Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,6"
                       Text="🔔 DeepSeek Credit Check" />

            <TextBlock Grid.Row="1" Grid.Column="0" FontSize="28" VerticalAlignment="Top"
                       Foreground="#FFA726" Text="⚠️" Margin="0,0,12,0" />

            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="MessageText" FontSize="13"
                       Foreground="#E0E0E0" TextWrapping="Wrap" VerticalAlignment="Center" />
        </Grid>
    </Border>
</Window>
