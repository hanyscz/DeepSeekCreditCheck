<Window x:Class="DeepSeekCreditCheck.UI.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ Nastavení"
        Width="520" Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        Foreground="#E0E0E0">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="SectionLabel">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="#E0E0E0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- API Key -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource SectionLabel}" Text="DeepSeek API Klíč" />
            <PasswordBox x:Name="ApiKeyBox"
                         PasswordChanged="ApiKeyBox_PasswordChanged"
                         Width="400" HorizontalAlignment="Left" />
            <TextBlock Text="Zadej API klíč z platform.deepseek.com/api_keys"
                       Foreground="#888" FontSize="11" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Alert Threshold -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource SectionLabel}" Text="Práh pro upozornění (USD)" />
            <TextBox Text="{Binding AlertThreshold, UpdateSourceTrigger=PropertyChanged}"
                     Width="100" HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Polling Interval -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource SectionLabel}" Text="Interval kontroly (minuty)" />
            <ComboBox ItemsSource="{Binding IntervalOptions}"
                      SelectedItem="{Binding PollingIntervalMin}"
                      Width="100" HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Language -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource SectionLabel}" Text="Jazyk / Language" />
            <ComboBox ItemsSource="{Binding AvailableLangs}"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="Code"
                      SelectedValue="{Binding SelectedLang}"
                      Width="160" HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Log Path -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource SectionLabel}" Text="Cesta k log souboru" />
            <TextBox Text="{Binding LogPath, UpdateSourceTrigger=PropertyChanged}"
                     Width="460" HorizontalAlignment="Left" />
            <TextBlock Text="Nech prázdné pro výchozí (%LocalAppData%\DeepSeekCreditCheck\app.log)"
                       Foreground="#777" FontSize="11" Margin="0,2,0,0" />
        </StackPanel>

        <!-- DB Path -->
        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource SectionLabel}" Text="Cesta k databázi (sdílení mezi PC)" />
            <TextBox Text="{Binding DbPath, UpdateSourceTrigger=PropertyChanged}"
                     Width="460" HorizontalAlignment="Left" />
            <TextBlock Text="Nech prázdné pro výchozí (%LocalAppData%\DeepSeekCreditCheck\data.db)"
                       Foreground="#777" FontSize="11" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,10,0,10">
            <Button Content="💾 Uložit" Command="{Binding SaveCommand}"
                    Width="100" Height="32" Margin="0,0,10,0"
                    Background="#0078D7" Foreground="White" BorderThickness="0"
                    Cursor="Hand" />
            <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                       FontSize="13" Foreground="#81C784" />
        </StackPanel>

        <TextBlock Grid.Row="7"
                   Text="Po uložení se aplikace restartuje s novým nastavením."
                   Foreground="#777" FontSize="11" VerticalAlignment="Bottom" />
    </Grid>
</Window>
