<Window x:Class="DeepSeekCreditCheck.UI.Windows.ViewDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📁 Historie zůstatků — DeepSeek Credit Checker"
        Width="800" Height="500"
        MinWidth="600" MinHeight="350"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        Foreground="#E0E0E0">
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="AlternatingRowBackground" Value="#252525" />
            <Setter Property="RowBackground" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="CanUserResizeColumns" Value="True" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2A2A2A" />
                        <Setter Property="Foreground" Value="#AAA" />
                        <Setter Property="BorderBrush" Value="#3A3A3A" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Padding" Value="8,6" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="#E0E0E0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252525" CornerRadius="6" Padding="14" Margin="0,0,0,10"
                BorderBrush="#3A3A3A" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📁 Historie zůstatků" FontSize="16" FontWeight="SemiBold" Foreground="#E0E0E0" />
                    <TextBlock Text="{Binding RecordCount, StringFormat='Celkem {0} záznamů'}"
                               FontSize="12" Foreground="#888" Margin="0,2,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="✕ Zavřít" Click="Close_Click"
                        Background="#3A3A3A" Foreground="#E0E0E0"
                        BorderThickness="0" Padding="12,6" Cursor="Hand"
                        FontSize="13" />
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1" x:Name="RecordsGrid" ItemsSource="{Binding Records}"
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Čas" Binding="{Binding Timestamp, StringFormat=\{0:dd.MM.yyyy HH:mm:ss\}}"
                                    Width="180" SortDirection="Descending" />
                <DataGridTextColumn Header="Dostupný" Binding="{Binding IsAvailable}"
                                    Width="80" />
                <DataGridTextColumn Header="Měna" Binding="{Binding Currency}"
                                    Width="60" />
                <DataGridTextColumn Header="Celkem" Binding="{Binding TotalBalanceDecimal, StringFormat=\{0:F2\}}"
                                    Width="100" />
                <DataGridTextColumn Header="Vlastní kredit" Binding="{Binding ToppedUpBalanceDecimal, StringFormat=\{0:F2\}}"
                                    Width="100" />
                <DataGridTextColumn Header="Grant" Binding="{Binding GrantedBalanceDecimal, StringFormat=\{0:F2\}}"
                                    Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer info -->
        <TextBlock Grid.Row="2" TextAlignment="Center" FontSize="11" Foreground="#666">
            Data se aktualizují při každém pollingu DeepSeek API
        </TextBlock>
    </Grid>
</Window>
