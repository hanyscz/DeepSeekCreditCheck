<Window x:Class="DeepSeekCreditCheck.UI.Windows.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="DeepSeek Kredit — Dashboard"
        Width="960" Height="680"
        MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        Foreground="#E0E0E0"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style TargetType="oxy:TrackerControl">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" BorderBrush="#555" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ArrowBtn" TargetType="Button">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#444444" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#555555" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#222222" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#1D1D1D" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#2A2A2A" />
                                <Setter Property="Foreground" Value="#555555" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                CornerRadius="8"
                Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🔄" FontSize="48" HorizontalAlignment="Center" />
                <TextBlock Text="Aktualizace dat..." FontSize="18" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,10,0,0" />
            </StackPanel>
        </Border>

        <!-- Stats Cards Row -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: Balance + prediction stacked -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="AKTUÁLNÍ ZŮSTATEK" FontSize="11" Foreground="#888" />
                    <TextBlock Text="{Binding CurrentBalance}" FontSize="32" FontWeight="Bold"
                               Foreground="#4FC3F7" Margin="0,2,0,4" />
                    <TextBlock FontSize="13" Foreground="#999" Margin="0,0,0,2">
                        <Run Text="Predikce:" />
                        <Run Text="{Binding Prediction}" FontWeight="SemiBold" Foreground="#81C784"
                             ToolTip="Počet dní do vyčerpání kreditu. Vypočteno jako zůstatek / průměrná denní spotřeba z dokončených dnů." />
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="#666">
                        <Run Text="průměr za kalendářní den" />
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#666" Margin="0,4,0,0">
                        <Run Text="Poslední aktualizace:" />
                        <Run Text="{Binding LastUpdated}" />
                    </TextBlock>
                </StackPanel>

                <!-- Today's spend -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="SPOTŘEBA DNES" FontSize="11" Foreground="#888" />
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding TodaySpend}"
                               Foreground="#FFB74D" ToolTip="Spotřeba kreditu za dnešní kalendářní den (první minus poslední hodnota dne)" />
                    <TextBlock Text="dnešní den" FontSize="10" Foreground="#666" />
                </StackPanel>

                <!-- Avg daily spend -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="PRŮMĚR/DEN" FontSize="11" Foreground="#888" />
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding AvgDailySpend}"
                               Foreground="#64B5F6" ToolTip="Průměrná denní spotřeba z dokončených kalendářních dnů (bez dneška). Ignoruje dobíjení." />
                    <TextBlock Text="z kalendářních dnů" FontSize="10" Foreground="#666" />
                </StackPanel>

                <!-- Weekly spend -->
                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="ZA TÝDEN" FontSize="11" Foreground="#888" />
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding WeeklySpend}"
                               Foreground="#FF8A65" ToolTip="Spotřeba za posledních 7 kalendářních dnů" />
                    <TextBlock Text="posledních 7 dní" FontSize="10" Foreground="#666" />
                </StackPanel>

                <!-- Monthly spend -->
                <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="ZA MĚSÍC" FontSize="11" Foreground="#888" />
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding MonthlySpend}"
                               Foreground="#E57373" ToolTip="Spotřeba za posledních 30 kalendářních dnů" />
                    <TextBlock Text="posledních 30 dní" FontSize="10" Foreground="#666" />
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Button Content="🔄 Obnovit" Command="{Binding RefreshCommand}"
                            Style="{StaticResource ActionBtn}" Margin="0,0,0,6" />
                    <Button Content="📁 Záznamy v DB" Command="{Binding OpenDataBrowserCommand}"
                            Style="{StaticResource ActionBtn}" Background="#2E7D32" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Platform Section -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16,14" MinHeight="130" Margin="0,0,0,12">
            <Grid>
                <!-- Grid pro nepřihlášený stav -->
                <Grid Visibility="{Binding IsPlatformDisconnected, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Chcete sledovat detailní spotřebu tokenů a přesné náklady?" 
                               VerticalAlignment="Center" FontSize="13" Foreground="#B0BEC5" />
                    <Button Grid.Column="1" Content="🔑 Propojit s platformou" 
                            Command="{Binding LoginPlatformCommand}" Style="{StaticResource ActionBtn}" Background="#0D47A1" BorderBrush="#1565C0" />
                </Grid>
                <!-- Grid pro přihlášený stav -->
                <Grid Visibility="{Binding IsPlatformConnected, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="6.5*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="DEEPSEEK PLATFORMA" FontSize="11" Foreground="#888" />
                        <TextBlock Text="Připojeno k účtu" FontSize="16" FontWeight="Bold" Foreground="#4FC3F7" Margin="0,2,0,4" />
                        <TextBlock FontSize="12" Foreground="#888">
                            <Run Text="Měsíc:" />
                            <Run Text="{Binding PlatformHeading}" FontWeight="SemiBold" Foreground="#81C784" />
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="◀" Command="{Binding PreviousMonthCommand}" Style="{StaticResource ArrowBtn}" ToolTip="Předchozí měsíc" />
                            <Button Content="▶" Command="{Binding NextMonthCommand}" Style="{StaticResource ArrowBtn}" Margin="8,0,0,0" ToolTip="Následující měsíc" />
                        </StackPanel>
                        <Button Content="📊 Podrobné statistiky" 
                                Command="{Binding OpenDetailedStatsCommand}"
                                Style="{StaticResource ActionBtn}" 
                                Margin="0,10,0,0" FontSize="11" Padding="8,4" HorizontalAlignment="Left" />
                    </StackPanel>

                    <!-- Tabulka s detailní spotřebou a cenou -->
                    <Grid Grid.Column="1" Margin="20,0,20,0" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="15" /> <!-- Hlavička -->
                            <RowDefinition Height="19" /> <!-- Pro -->
                            <RowDefinition Height="19" /> <!-- Flash -->
                            <RowDefinition Height="19" /> <!-- Celkem -->
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55" /> <!-- Model name -->
                            <ColumnDefinition Width="*" />  <!-- Input -->
                            <ColumnDefinition Width="*" />  <!-- Cache -->
                            <ColumnDefinition Width="*" />  <!-- Output -->
                            <ColumnDefinition Width="1.2*" />  <!-- Total tokens -->
                            <ColumnDefinition Width="1.2*" />  <!-- Price -->
                        </Grid.ColumnDefinitions>

                        <!-- Hlavičkový řádek (Řádek 0) -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Model" FontSize="10" Foreground="#888" FontWeight="Bold" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Input (Miss)" FontSize="10" Foreground="#888" FontWeight="Bold" TextAlignment="Right" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Cache (Hit)" FontSize="10" Foreground="#888" FontWeight="Bold" TextAlignment="Right" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Output" FontSize="10" Foreground="#888" FontWeight="Bold" TextAlignment="Right" />
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Celkem" FontSize="10" Foreground="#888" FontWeight="Bold" TextAlignment="Right" />
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="Cena (USD)" FontSize="10" Foreground="#888" FontWeight="Bold" TextAlignment="Right" />

                        <!-- Oddělovač pod hlavičkou -->
                        <Border Grid.Row="0" Grid.ColumnSpan="6" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1" VerticalAlignment="Bottom" Height="2" Margin="0,0,0,0" />

                        <!-- Pro Řádek (Řádek 1) -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Pro" FontSize="11" Foreground="#E0E0E0" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PlatformProInput}" FontSize="11" Foreground="#B0BEC5" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding PlatformProCache}" FontSize="11" Foreground="#90A4AE" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding PlatformProOutput}" FontSize="11" Foreground="#B0BEC5" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding PlatformProTotal}" FontSize="11" Foreground="#81C784" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="1" Grid.Column="5" Text="{Binding PlatformProCost}" FontSize="11" Foreground="#FFB74D" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />

                        <!-- Flash Řádek (Řádek 2) -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Flash" FontSize="11" Foreground="#E0E0E0" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PlatformFlashInput}" FontSize="11" Foreground="#B0BEC5" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding PlatformFlashCache}" FontSize="11" Foreground="#90A4AE" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding PlatformFlashOutput}" FontSize="11" Foreground="#B0BEC5" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding PlatformFlashTotal}" FontSize="11" Foreground="#81C784" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="2" Grid.Column="5" Text="{Binding PlatformFlashCost}" FontSize="11" Foreground="#FFB74D" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />

                        <!-- Oddělovač nad Celkem -->
                        <Border Grid.Row="2" Grid.ColumnSpan="6" BorderBrush="#444" BorderThickness="0,0,0,1" VerticalAlignment="Bottom" Height="2" Margin="0,0,0,0" />

                        <!-- Celkem Řádek (Řádek 3) -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Celkem" FontSize="11" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PlatformTotalInput}" FontSize="11" Foreground="White" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding PlatformTotalCache}" FontSize="11" Foreground="#A5D6A7" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding PlatformTotalOutput}" FontSize="11" Foreground="White" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="3" Grid.Column="4" Text="{Binding PlatformTotalTotal}" FontSize="12" Foreground="#81C784" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                        <TextBlock Grid.Row="3" Grid.Column="5" Text="{Binding PlatformTotalCost}" FontSize="12" Foreground="#FFB74D" FontWeight="Bold" TextAlignment="Right" VerticalAlignment="Center" Margin="0,3" />
                    </Grid>

                    <Button Grid.Column="2" Content="Odpojit" 
                            Command="{Binding LogoutPlatformCommand}" Style="{StaticResource ActionBtn}" Background="#D32F2F" BorderBrush="#C62828" VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>

        <!-- Update Banner -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="10,6"
                Background="#1E3A2F" BorderBrush="#2E7D32"
                Margin="0,0,0,8"
                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding UpdateBannerText}"
                           FontSize="13" Foreground="#A5D6A7" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="⬇ Stáhnout"
                        Command="{Binding DownloadUpdateCommand}"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        Padding="12,4" FontSize="12" Cursor="Hand" />
            </Grid>
        </Border>

        <!-- Spend Chart -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="0">
            <oxy:PlotView Model="{Binding SpendPlot}" Background="#161616" />
        </Border>
    </Grid>
</Window>
