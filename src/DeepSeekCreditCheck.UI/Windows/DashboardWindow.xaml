<Window x:Class="DeepSeekCreditCheck.UI.Windows.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="DeepSeek Kredit — Dashboard"
        Width="960" Height="680"
        MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        Foreground="#E0E0E0"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style TargetType="oxy:TrackerControl">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" BorderBrush="#555" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Stats Cards Row -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: Balance + prediction stacked -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="AKTUÁLNÍ ZŮSTATEK" FontSize="11" Foreground="#888" />
                    <TextBlock Text="{Binding CurrentBalance}" FontSize="32" FontWeight="Bold"
                               Foreground="#4FC3F7" Margin="0,2,0,4" />
                    <TextBlock FontSize="13" Foreground="#999" Margin="0,0,0,2">
                        <Run Text="Predikce:" />
                        <Run Text="{Binding Prediction}" FontWeight="SemiBold" Foreground="#81C784"
                             ToolTip="Počet dní do vyčerpání kreditu při průměrné denní spotřebě" />
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="#666">
                        <Run Text="průměr za kalendářní den" />
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#666" Margin="0,4,0,0">
                        <Run Text="Poslední aktualizace:" />
                        <Run Text="{Binding LastUpdated}" />
                    </TextBlock>
                </StackPanel>

                <!-- Avg daily spend -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="PRŮMĚR/DEN" FontSize="11" Foreground="#888" />
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding AvgDailySpend}"
                               Foreground="#64B5F6" ToolTip="Průměrná denní spotřeba za kalendářní den (00:00–23:59 UTC)" />
                    <TextBlock Text="z kalendářních dnů" FontSize="10" Foreground="#666" />
                </StackPanel>

                <!-- Weekly spend -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="ZA TÝDEN" FontSize="11" Foreground="#888" />
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding WeeklySpend}"
                               Foreground="#FF8A65" ToolTip="Spotřeba za posledních 7 kalendářních dnů" />
                    <TextBlock Text="posledních 7 dní" FontSize="10" Foreground="#666" />
                </StackPanel>

                <!-- Monthly spend -->
                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="ZA MĚSÍC" FontSize="11" Foreground="#888" />
                    <TextBlock Style="{StaticResource StatValue}" Text="{Binding MonthlySpend}"
                               Foreground="#E57373" ToolTip="Spotřeba za posledních 30 kalendářních dnů" />
                    <TextBlock Text="posledních 30 dní" FontSize="10" Foreground="#666" />
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Button Content="🔄 Obnovit" Command="{Binding RefreshCommand}"
                            Style="{StaticResource ActionBtn}" Margin="0,0,0,6" />
                    <Button Content="📁 Záznamy v DB" Command="{Binding OpenDataBrowserCommand}"
                            Style="{StaticResource ActionBtn}" Background="#2E7D32" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Balance Chart -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0" Margin="0,0,0,8">
            <oxy:PlotView Model="{Binding BalancePlot}" Background="#161616" />
        </Border>

        <!-- Spend Chart -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <oxy:PlotView Model="{Binding SpendPlot}" Background="#161616" />
        </Border>
    </Grid>
</Window>
